import React, { useState } from 'react';
import { StyleSheet, Text, View, TextInput, TouchableOpacity, ScrollView, SafeAreaView, StatusBar } from 'react-native';

export default function App() {
  const [inputValue, setInputValue] = useState('');
  const [result, setResult] = useState(null);

  const calculateTarget = () => {
    if (inputValue) {
      // G-350 ELITE FORMULA: Change 1.35 to your secret multiplier
      const finalTarget = (parseFloat(inputValue) * 1.35).toFixed(2);
      setResult(finalTarget);
    }
  };

  return (
    <SafeAreaView style={styles.container}>
      <StatusBar barStyle="light-content" />
      <ScrollView contentContainerStyle={styles.content}>
        <Text style={styles.brand}>GALLEON GAIN</Text>
        <Text style={styles.title}>G-350 ELITE</Text>
        <Text style={styles.subtitle}>TARGET ENGINE v1.0</Text>

        <View style={styles.inputCard}>
          <Text style={styles.label}>INPUT CURRENT METRICS</Text>
          <TextInput
            style={styles.inputField}
            placeholder="ENTER VALUE"
            placeholderTextColor="#444"
            keyboardType="numeric"
            value={inputValue}
            onChangeText={setInputValue}
          />
          <TouchableOpacity style={styles.btn} onPress={calculateTarget}>
            <Text style={styles.btnText}>RUN ENGINE</Text>
          </TouchableOpacity>
        </View>

        {result && (
          <View style={styles.resultCard}>
            <Text style={styles.resultLabel}>G-350 TARGET OUTPUT</Text>
            <Text style={styles.resultValue}>{result}</Text>
          </View>
        )}
      </ScrollView>
    </SafeAreaView>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#000' },
  content: { padding: 30, alignItems: 'center' },
  brand: { color: '#666', fontSize: 12, letterSpacing: 5, marginBottom: 5 },
  title: { color: '#fff', fontSize: 42, fontWeight: '900', letterSpacing: 2 },
  subtitle: { color: '#FFD700', fontSize: 14, fontWeight: 'bold', letterSpacing: 3, marginBottom: 50 },
  inputCard: { width: '100%', backgroundColor: '#0a0a0a', padding: 25, borderRadius: 20, borderWidth: 1, borderColor: '#222' },
  label: { color: '#555', fontSize: 10, fontWeight: 'bold', marginBottom: 15, letterSpacing: 1 },
  inputField: { backgroundColor: '#111', color: '#fff', padding: 20, borderRadius: 12, fontSize: 24, marginBottom: 20, textAlign: 'center', borderWidth: 1, borderColor: '#333' },
  btn: { backgroundColor: '#fff', padding: 20, borderRadius: 12, alignItems: 'center' },
  btnText: { color: '#000', fontWeight: '900', fontSize: 16, letterSpacing: 1 },
  resultCard: { marginTop: 40, width: '100%', padding: 30, backgroundColor: '#FFD700', borderRadius: 20, alignItems: 'center' },
  resultLabel: { color: '#000', fontSize: 11, fontWeight: '900', letterSpacing: 1, marginBottom: 10 },
  resultValue: { color: '#000', fontSize: 56, fontWeight: '900' },
});
